{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BIOS Flasher Professional",
  "version": "2.1.4",
  "identifier": "com.megapass.bios-flasher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "\ud83d\udd27 BIOS Flasher - By Megapass Sidoarjo v2.1.4",
        "width": 1100,
        "height": 800,
        "resizable": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
